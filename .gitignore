# ============================================================
# naruto-auto-daily · .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual env
.venv/
venv/
env/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# pytest / 测试缓存
.pytest_cache/
.coverage
htmlcov/
.tox/

# 日志
logs/
*.log
!logs/.gitkeep

# 运行时截图存档
screenshots/
!screenshots/.gitkeep
# 例外:failures/ 子目录保留(节点失败截图,排查用)
!screenshots/failures/.gitkeep

# 配置中的本地路径(每台机器不同,不要 commit)
config/*.local.yaml
config/*.local.yml

# 凭据 / 私密
*.pem
*.key
secrets.yaml

# 临时文件
*.tmp
*.bak
*.orig
~$*

# MaaFramework 运行时数据
logs/maafw_data/

# AI agent 本地配置(开发工具本地缓存,不入仓库)
.claude/

# ============================================================
# Frontend (MFAAvalonia) — 扁平化 (2026-07-20 目录扁平化重构)
# ============================================================
# git 追踪(任务编排 + 配置):
#   interface.json
#   appsettings.json
#   config/instances/default.json
# CI/CD: GitHub Actions 在打 release 时从 MaaXYZ/MaaFramework releases 下载
#   MFAAvalonia 主程序,再用 git 里的配置文件覆盖默认。

# Frontend 二进制主体(MaaFramework 官方 ~235MB,本地开发用,CI 自动下载)
MFAAvalonia.exe
MFAAvalonia.dll
MFAAvalonia.deps.json
MFAAvalonia.runtimeconfig.json
libloader.dll
DependencySetup_依赖库安装_win.bat
dependencySetup_*.bat
runtimes/
python/
libs/
plugins/
agent/                  # 默认 ignore 所有 agent/ 子目录 (如 frontend 残留)
!/agent/                 # 例外: 重新包含根 agent/ 源码
resource/
Resource/
resources/
ThirdParty/
backup/
debug/
logs/
temp/
# .bak 备份文件(本地开发残留,不入库)
interface.json.bak
config/instances/*.bak
*.bak
# 上游默认配置(MFAAvalonia 自带,不需要我们追踪)
config/config.json
config/maa_option.json
config/maa_pi_config.json
# 平台相关 native 库(Windows-only,本项目只发布 Windows)
*.so
*.dylib

# 项目数据
data/
*.csv
*.db
*.sqlite3

# 调试期临时产物(本地分析报告,不入仓库)
/findings_*.json
/resources/narutomobile/_test_backups/

# 目录扁平化重构时的备份(如果还在可以删掉,不要 commit)
/frontend.bak.*/

# 内部 roadmap 草稿(开发期讨论记录,非用户文档)
docs/superpowers/
