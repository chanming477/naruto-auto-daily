# ============================================================
# naruto-auto-daily · .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual env
.venv/
venv/
env/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# pytest / 测试缓存
.pytest_cache/
.coverage
htmlcov/
.tox/

# 日志
logs/
*.log
!logs/.gitkeep

# 运行时截图存档
screenshots/
!screenshots/.gitkeep
# 例外:failures/ 子目录保留(节点失败截图,排查用)
!screenshots/failures/.gitkeep

# 配置中的本地路径(每台机器不同,不要 commit)
config/*.local.yaml
config/*.local.yml

# 凭据 / 私密
*.pem
*.key
secrets.yaml

# 临时文件
*.tmp
*.bak
*.orig
~$*

# MaaFramework 运行时数据
logs/maafw_data/

# AI agent 本地配置(开发工具本地缓存,不入仓库)
.claude/

# ============================================================
# Frontend (MFAAvalonia) — 部分追踪,部分 ignore (2026-07-20 CI/CD 重构)
# ============================================================
# git 追踪(任务编排 + 配置):
#   frontend/MFAAvalonia/interface.json
#   frontend/MFAAvalonia/appsettings.json
#   frontend/MFAAvalonia/config/instances/default.json
# CI/CD: GitHub Actions 在打 release 时从 MaaXYZ/MaaFramework releases 下载
#   MFAAvalonia 主程序,再用 git 里的配置文件覆盖默认。

# Frontend 二进制主体(MaaFramework 官方 ~235MB,本地开发用,CI 自动下载)
frontend/MFAAvalonia/MFAAvalonia.exe
frontend/MFAAvalonia/MFAAvalonia.dll
frontend/MFAAvalonia/MFAAvalonia.deps.json
frontend/MFAAvalonia/MFAAvalonia.runtimeconfig.json
frontend/MFAAvalonia/libloader.dll
frontend/MFAAvalonia/DependencySetup_依赖库安装_win.bat
frontend/MFAAvalonia/dependencySetup_*.bat
frontend/MFAAvalonia/runtimes/
frontend/MFAAvalonia/python/
frontend/MFAAvalonia/libs/
frontend/MFAAvalonia/plugins/
frontend/MFAAvalonia/agent/
frontend/MFAAvalonia/resource/
frontend/MFAAvalonia/Resource/
frontend/MFAAvalonia/resources/
frontend/MFAAvalonia/ThirdParty/
frontend/MFAAvalonia/backup/
frontend/MFAAvalonia/debug/
frontend/MFAAvalonia/logs/
frontend/MFAAvalonia/temp/
# .bak 备份文件(本地开发残留,不入库)
frontend/MFAAvalonia/interface.json.bak
frontend/MFAAvalonia/config/instances/*.bak
frontend/MFAAvalonia/*.bak
# 上游默认配置(MFAAvalonia 自带,不需要我们追踪)
frontend/MFAAvalonia/config/config.json
frontend/MFAAvalonia/config/maa_option.json
frontend/MFAAvalonia/config/maa_pi_config.json
# 平台相关 native 库(Windows-only,本项目只发布 Windows)
frontend/MFAAvalonia/*.so
frontend/MFAAvalonia/*.dylib

# 项目数据
data/
*.csv
*.db
*.sqlite3

# 调试期临时产物(本地分析报告,不入仓库)
/findings_*.json
/resources/narutomobile/_test_backups/

# 内部 roadmap 草稿(开发期讨论记录,非用户文档)
docs/superpowers/
