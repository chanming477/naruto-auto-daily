# ============================================================
# naruto-auto-daily · .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual env
.venv/
venv/
env/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# pytest / 测试缓存
.pytest_cache/
.coverage
htmlcov/
.tox/

# 日志
logs/
*.log
!logs/.gitkeep

# 运行时截图存档
screenshots/
!screenshots/.gitkeep
# 例外:failures/ 子目录保留(节点失败截图,排查用)
!screenshots/failures/.gitkeep

# 配置中的本地路径(每台机器不同,不要 commit)
config/*.local.yaml
config/*.local.yml

# 凭据 / 私密
*.pem
*.key
secrets.yaml

# 临时文件
*.tmp
*.bak
*.orig
~$*

# MaaFramework 运行时数据
logs/maafw_data/

# AI agent 本地配置(开发工具本地缓存,不入仓库)
.claude/

# Frontend 二进制发布(MaaFramework 官方 MFAAvalonia,~234 MB)
# 用户首次运行前需手动从 GitHub releases 下载解压到 frontend/MFAAvalonia/
# 详见 README §3 快速开始 + start.bat 启动时的下载提示
frontend/MFAAvalonia/

# 项目数据
data/
*.csv
*.db
*.sqlite3

# 调试期临时产物(本地分析报告,不入仓库)
/findings_*.json
/resources/narutomobile/_test_backups/

# 内部 roadmap 草稿(开发期讨论记录,非用户文档)
docs/superpowers/
